# PostgreSQL connection string (Neon, eu-central-1).
# Use Neon's "pooled" connection string for the app and
# the "direct" connection string for migrations if needed.
# Include sslmode=require for Neon.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Random string used to sign session cookies. Use 64+ random bytes.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-long-random-string

# Node environment. Set to "production" on Render.
NODE_ENV=development

# Port the Express server listens on. Render sets this automatically.
PORT=3000
