+                    onChange={(e) =>
+                      setDraft({ ...draft, [d.deviceId]: Math.max(0, Number(e.target.value || 0)) })
+                    }
+                  />
+                </div>
+              </div>
+            ))}
+          </div>
+        )}
+        <div className="flex justify-end mt-4">
+          <Button onClick={() => saveMut.mutate()} disabled={saveMut.isPending || branchId === null}>
